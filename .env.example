# Copy to .env.local for local dev, and set the same values in Vercel
# (Project -> Settings -> Environment Variables) for production.

# Shared secret. TradingView's webhook URL must end with ?token=THIS_VALUE
# Generate something long/random, e.g. `openssl rand -hex 24`
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Which WhatsApp gateway you signed up for: "whapi" or "wassenger"
WA_PROVIDER=whapi

# API token from the gateway dashboard
WA_TOKEN=your-gateway-api-token

# The WhatsApp group id for "Ichimoku", e.g. 120363041234567890@g.us
# (see README for how to find it)
WA_GROUP_ID=120363xxxxxxxxxxxx@g.us
